# Runtime mode
AIA_USE_REAL_SERVICES=false
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379/0
REDIS_RESPONSE_TTL_SECONDS=300
REDIS_RATE_LIMIT_PER_MINUTE=60

# MongoDB conversation memory
MONGO_ENABLED=false
MONGO_URL=mongodb://mongo:27017
MONGO_DB_NAME=aia
CONTEXT_RECENT_MESSAGES=8
CONTEXT_MAX_MESSAGES=20

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Qdrant (local docker default; no API key needed)
# Use http://localhost:6333 for host run, or http://qdrant:6333 when running via docker compose
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTIONS=taxonomy,rules,examples

# Jira
JIRA_BASE_URL=https://your-domain.atlassian.net/
JIRA_EMAIL=
JIRA_API_TOKEN=

# Slack (currently not supported for execution in this environment)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# Observability (optional)
LANGSMITH_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
