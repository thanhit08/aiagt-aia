{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aia.local/schemas/v1/parsed_issue.schema.json",
  "title": "ParsedIssue",
  "type": "object",
  "additionalProperties": false,
  "required": ["issue_id", "title", "description", "steps", "severity"],
  "properties": {
    "issue_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "title": { "type": "string", "minLength": 1, "maxLength": 300 },
    "description": { "type": "string", "minLength": 1, "maxLength": 5000 },
    "steps": { "type": "string", "minLength": 1, "maxLength": 5000 },
    "severity": {
      "type": "string",
      "enum": ["blocker", "critical", "major", "minor", "trivial", "unknown"]
    },
    "component": { "type": "string", "maxLength": 120 },
    "environment": { "type": "string", "maxLength": 120 }
  }
}
