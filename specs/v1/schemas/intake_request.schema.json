{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aia.local/schemas/v1/intake_request.schema.json",
  "title": "IntakeRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "user_id", "instruction", "file_meta"],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "instruction": {
      "type": "string",
      "minLength": 3,
      "maxLength": 4000
    },
    "file_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filename", "content_type", "size_bytes"],
      "properties": {
        "filename": { "type": "string", "minLength": 1 },
        "content_type": {
          "type": "string",
          "enum": [
            "text/csv",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            "text/markdown",
            "text/plain"
          ]
        },
        "size_bytes": { "type": "integer", "minimum": 1, "maximum": 5242880 }
      }
    }
  }
}
