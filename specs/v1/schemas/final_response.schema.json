{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aia.local/schemas/v1/final_response.schema.json",
  "title": "FinalResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "answer", "trace_id", "action_results", "errors"],
  "properties": {
    "request_id": {"type": "string", "minLength": 1},
    "answer": {"type": "string", "minLength": 1},
    "trace_id": {"type": "string", "minLength": 1, "maxLength": 200},
    "action_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["system", "action", "status"],
        "properties": {
          "system": {"type": "string", "enum": ["jira", "slack"]},
          "action": {"type": "string", "minLength": 3},
          "status": {"type": "string", "enum": ["success", "failed", "skipped"]},
          "data": {"type": "object"},
          "error": {"type": "string"}
        }
      }
    },
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
