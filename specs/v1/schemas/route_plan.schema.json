{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aia.local/schemas/v1/route_plan.schema.json",
  "title": "RoutePlan",
  "type": "object",
  "additionalProperties": false,
  "required": ["action_plans", "parallel"],
  "properties": {
    "parallel": {"type": "boolean"},
    "action_plans": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["system", "action", "params", "risk_level", "depends_on"],
        "properties": {
          "system": {"type": "string", "enum": ["jira", "slack"]},
          "action": {"type": "string", "minLength": 3, "maxLength": 80},
          "params": {"type": "object"},
          "risk_level": {"type": "string", "enum": ["low", "medium", "high"]},
          "depends_on": {
            "type": "array",
            "items": {"type": "string", "minLength": 1, "maxLength": 64}
          }
        }
      }
    }
  }
}
