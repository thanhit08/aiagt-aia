{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aia.local/schemas/v1/enriched_task.schema.json",
  "title": "EnrichedTask",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_type", "requires_rag", "output_tone", "action_plans"],
  "properties": {
    "task_type": {
      "type": "string",
      "enum": ["general_query", "tool_orchestration", "summarization", "analysis", "triage"]
    },
    "requires_rag": {"type": "boolean"},
    "output_tone": {
      "type": "string",
      "enum": ["executive", "neutral", "technical"]
    },
    "rag_query_seed": {"type": "string", "minLength": 0, "maxLength": 1000},
    "action_plans": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["system", "action", "params", "risk_level", "depends_on"],
        "properties": {
          "system": {"type": "string", "enum": ["jira", "slack", "telegram"]},
          "action": {"type": "string", "minLength": 3, "maxLength": 80},
          "params": {"type": "object"},
          "risk_level": {"type": "string", "enum": ["low", "medium", "high"]},
          "depends_on": {
            "type": "array",
            "items": {"type": "string", "minLength": 1, "maxLength": 64}
          }
        }
      }
    }
  }
}

