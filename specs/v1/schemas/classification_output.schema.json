{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aia.local/schemas/v1/classification_output.schema.json",
  "title": "ClassificationOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["issue_id", "accuracy_related", "confidence", "reason"],
  "properties": {
    "issue_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "accuracy_related": { "type": "boolean" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "reason": { "type": "string", "minLength": 1, "maxLength": 500 }
  },
  "allOf": [
    {
      "if": {
        "properties": { "accuracy_related": { "const": true } },
        "required": ["accuracy_related"]
      },
      "then": {
        "properties": {
          "reason": { "minLength": 8 }
        }
      }
    }
  ]
}
